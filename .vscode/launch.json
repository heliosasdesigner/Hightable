{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Open Hightable Desktop",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron",
      "windows": {
        "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron.cmd"
      },
      "args": ["--remote-debugging-port=9333", "."],
      "env": {
        "VITE_DEV_SERVER_URL": "http://127.0.0.1:5300",
        "ELECTRON_ENABLE_LOGGING": "true"
      },
      "console": "integratedTerminal",
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "desktop: prepare"
    },
    {
      "name": "Attach Hightable Renderer",
      "type": "chrome",
      "request": "attach",
      "port": 9333,
      "webRoot": "${workspaceFolder}/src/renderer",
      "timeout": 30000
    }
  ],
  "compounds": [
    {
      "name": "Open Hightable Desktop + Renderer Debug",
      "configurations": ["Open Hightable Desktop", "Attach Hightable Renderer"],
      "stopAll": true
    }
  ]
}
